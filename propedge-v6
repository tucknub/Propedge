}
.clash-edge b { color: var(–text); font-weight: 600; }

/* ─── MODAL ─── */
.modal-overlay {
position: fixed;
inset: 0;
background: rgba(0,0,0,0.88);
z-index: 1000;
display: flex;
align-items: flex-start;
justify-content: center;
padding: 40px 16px;
overflow-y: auto;
opacity: 0;
pointer-events: none;
transition: opacity 0.2s;
}
.modal-overlay.open { opacity: 1; pointer-events: all; }
.modal-box {
background: var(–s1);
border: 1px solid var(–b2);
border-radius: 14px;
width: 100%;
max-width: 640px;
position: relative;
margin: auto;
}
.modal-header {
padding: 22px 28px 18px;
border-bottom: 1px solid var(–b1);
display: flex;
align-items: center;
justify-content: space-between;
position: sticky;
top: 0;
background: var(–s1);
z-index: 2;
