<script>
// ════════════════════════════════════════════
// PROPEDGE AI v6.6 — batter footer badge also year-gated (PRIOR SEASON when year < 2026)
// All endpoints verified live from browser
//
// MLB Stats API (CORS open):
//   /people/{id}                  → bio
//   /people/{id}?hydrate=stats... → hitting stats
//   /schedule?hydrate=...         → games + weather
//
// Baseball Savant via corsproxy.io:
//   /leaderboard/expected_statistics?csv=true → xBA, xSLG, xwOBA
//   /leaderboard/statcast?csv=true            → Barrel%, EV95%, AvgEV
// ════════════════════════════════════════════

const MLB    = 'https://statsapi.mlb.com/api/v1';
const SAVANT = 'https://baseballsavant.mlb.com';

// Multi-proxy race — fire all simultaneously, take first success
const PROXIES = [
  url => `https://corsproxy.io/?${encodeURIComponent(url)}`,
  url => `https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`,
  url => `https://api.codetabs.com/v1/proxy?quest=${url}`,
  url => `https://thingproxy.freeboard.io/fetch/${url}`,
];

async function fetchSavantCSV(path, timeoutMs = 12000) {
  const fullUrl = `${SAVANT}${path}`;
  const attempts = PROXIES.map(proxy => (async () => {
    const res = await fetch(proxy(fullUrl), { signal: AbortSignal.timeout(timeoutMs) });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const txt = await res.text();
    if (!txt || txt.trim().startsWith('<') || txt.trim().startsWith('<!')) throw new Error('HTML response — proxy blocked');
    return txt;
  })());
  // Race: first non-error wins
  try {
    return await Promise.any(attempts);
  } catch {
    return null;
  }
}


// ── EDITABLE LINE HELPERS ──
function calcKEV(projVal, line) {
  const l = parseFloat(line);
  if (!l || !projVal) return '—';
  const diff = projVal / l - 1;
  if (diff > 0.03)  return `+${Math.round(diff*100)}%`;
  if (diff < -0.03) return `-${Math.abs(Math.round(diff*100))}%`;
  return '—';
}
function calcKRec(projVal, line) {
  const l = parseFloat(line);
  if (!l || !projVal) return 'WATCH';
  if (projVal >= l * 1.03) return 'OVER';
  if (projVal <= l * 0.97) return 'UNDER';
  return 'WATCH';
}
function recalcKProp(id, projVal) {
  const input = document.getElementById(id);
  if (!input) return;
  const line = parseFloat(input.value);
  if (!line || line <= 0) return;
  const ev  = calcKEV(projVal, line);
  const rec = calcKRec(projVal, line);
  const evEl  = document.getElementById('ev_'+id);
  const recEl = document.getElementById('rec_'+id);
  if (evEl) {
    evEl.textContent = ev;
    evEl.style.color = ev.startsWith('+') ? 'var(--green)' : ev.startsWith('-') ? 'var(--red)' : 'var(--muted)';
  }
  if (recEl) {
    recEl.textContent = rec;
    recEl.className = 'prop-rec ' + (rec==='OVER'?'rec-over':rec==='UNDER'?'rec-under':'rec-watch');
  }
  // Update market label
  const mktEl = document.getElementById('mkt_'+id);
  if (mktEl) {
    if (!mktEl.dataset.base) mktEl.dataset.base = mktEl.textContent.replace(/\s+O\/U.*$/, '').trim();
    mktEl.textContent = mktEl.dataset.base + ' O/U ' + line;
  }
}
function snapKLine(id, projVal) {
  // Snap to nearest 0.5 on blur
  const input = document.getElementById(id);
  if (!input) return;
  const raw = parseFloat(input.value);
  if (!raw || raw <= 0) { input.value = 0.5; return; }
  const snapped = Math.round(raw * 2) / 2;
  input.value = snapped;
  recalcKProp(id, projVal);
}
// ── SCREENS ──
function show(id) {
  ['searchScreen','loadingScreen','cardScreen'].forEach(s => {
    document.getElementById(s).style.display = s===id ? 'flex' : 'none';
  });

}
show('searchScreen');

// ── SEARCH ──
const inp  = document.getElementById('searchInput');
const drop = document.getElementById('searchDrop');
let timer  = null;
let searchMode = 'batter'; // 'batter' | 'pitcher'

function setMode(mode) {
  searchMode = mode;
  document.getElementById('modeBatter').classList.toggle('active', mode === 'batter');
  document.getElementById('modePitcher').classList.toggle('active', mode === 'pitcher');
  inp.placeholder = mode === 'pitcher' ? 'Search pitcher name...' : 'Search batter name...';
  document.getElementById('searchSubtitle').textContent = mode === 'pitcher'
    ? 'MLB · Pitcher Card · 2026'
    : 'MLB · Batter + Pitcher Matchup · 2026';
  drop.classList.remove('open');
  drop.innerHTML = '';
  // Keep whatever the user has typed — just re-search with new mode filter
  inp.focus();
  if (inp.value.trim().length >= 2) {
    drop.innerHTML = `<div class="sr-item"><span class="sr-meta">Searching...</span></div>`;
    drop.classList.add('open');
    clearTimeout(timer);
    timer = setTimeout(() => doSearch(inp.value.trim()), 150);
  }
}

inp.addEventListener('input', () => {
  const q = inp.value.trim();
  clearTimeout(timer);
  if (q.length < 2) { drop.classList.remove('open'); drop.innerHTML=''; return; }
  drop.innerHTML = `<div class="sr-item"><span class="sr-meta">Searching...</span></div>`;
  drop.classList.add('open');
  timer = setTimeout(() => doSearch(q), 320);
});
inp.addEventListener('keydown', e => { if(e.key==='Escape') drop.classList.remove('open'); });
document.addEventListener('click', e => { if(!e.target.closest('.search-wrap')) drop.classList.remove('open'); });

async function doSearch(q) {
  try {
    const res  = await fetch(`${MLB}/people/search?names=${encodeURIComponent(q)}&sportId=1&active=true`);
    const data = await res.json();
    let hits;
    if (searchMode === 'pitcher') {
      hits = (data.people||[]).filter(p => p.primaryPosition?.type === 'Pitcher').slice(0,8);
      if (!hits.length) {
        // Check if there are position players with this name
        const batterHits = (data.people||[]).filter(p => p.primaryPosition?.type !== 'Pitcher').slice(0,3);
        if (batterHits.length) {
          drop.innerHTML = `
            <div class="sr-item" style="border-bottom:1px solid var(--border);pointer-events:none;">
              <span class="sr-meta" style="color:var(--yellow)">⚠ No pitchers found — did you mean a position player?</span>
            </div>` +
            batterHits.map(p=>`
            <div class="sr-item" onclick="setMode('batter'); go(${p.id},'${esc(p.fullName)}')">
              <span class="sr-name">${esc(p.fullName)}</span>
              <span class="sr-meta">${p.primaryPosition?.abbreviation||'?'} · ${p.currentTeam?.name||'?'} · <span style="color:var(--accent)">Switch to ⚾ Batter mode</span></span>
            </div>`).join('');
          drop.classList.add('open');
        } else {
          drop.innerHTML=`<div class="sr-item"><span class="sr-meta">No active pitchers found — try a different name</span></div>`;
        }
        return;
      }
    } else {
      hits = (data.people||[]).filter(p => p.primaryPosition?.type !== 'Pitcher').slice(0,8);
      if (!hits.length) {
        // Check if there are pitchers with this name — offer disambiguation
        const pitcherHits = (data.people||[]).filter(p => p.primaryPosition?.type === 'Pitcher').slice(0,3);
        if (pitcherHits.length) {
          drop.innerHTML = `
            <div class="sr-item" style="border-bottom:1px solid var(--border);pointer-events:none;">
              <span class="sr-meta" style="color:var(--yellow)">⚠ No position players found — did you mean a pitcher?</span>
            </div>` +
            pitcherHits.map(p=>`
            <div class="sr-item" onclick="setMode('pitcher'); goPitcher(${p.id},'${esc(p.fullName)}')">
              <span class="sr-name">${esc(p.fullName)}</span>
              <span class="sr-meta">${p.primaryPosition?.abbreviation||'P'} · ${p.currentTeam?.name||'?'} · <span style="color:var(--accent)">Switch to ⚡ Pitcher mode</span></span>
            </div>`).join('');
          drop.classList.add('open');
        } else {
          drop.innerHTML=`<div class="sr-item"><span class="sr-meta">No active position players found</span></div>`;
        }
        return;
      }
    }
    drop.innerHTML = hits.map(p=>`
      <div class="sr-item" onclick="${searchMode === 'pitcher' ? 'goPitcher' : 'go'}(${p.id},'${esc(p.fullName)}')">
        <span class="sr-name">${esc(p.fullName)}</span>
        <span class="sr-meta">${p.primaryPosition?.abbreviation||'?'} · ${p.currentTeam?.name||'?'}</span>
      </div>`).join('');
    drop.classList.add('open');
  } catch(e) {
    drop.innerHTML=`<div class="sr-item"><span class="sr-meta" style="color:var(--red)">Error: ${esc(e.message)}</span></div>`;
  }
}

// ── MAIN FLOW ──
// ── PITCHER-ONLY FLOW ──
async function goPitcher(pitcherId, pitcherName) {
  drop.classList.remove('open');
  inp.value = '';
  document.getElementById('loadingName').textContent = pitcherName;
  show('loadingScreen');
  resetSteps();

  // Repurpose steps 1-5 for pitcher-only labels
  document.getElementById('s1t').textContent = 'Pitcher bio · MLB Stats API...';
  document.getElementById('s2t').textContent = 'Pitcher stats · MLB Stats API...';
  document.getElementById('s3t').textContent = 'xERA / xBA / xwOBA · Baseball Savant...';
  document.getElementById('s4t').textContent = 'K% / Whiff% / HardHit% · Baseball Savant...';
  document.getElementById('s5t').textContent = 'Schedule · MLB Stats API...';
  document.getElementById('s6t').textContent = '—';
  document.getElementById('s7t').textContent = '—';
  document.getElementById('s8t').textContent = '—';
  document.getElementById('s9t').textContent = 'Building pitcher card...';

  try {
    step(1,'loading');
    const pitcherBio = await getPitcherBio(pitcherId);
    step(1,'done',`✓ ${pitcherBio.fullName} · ${pitcherBio.currentTeam?.name||'?'}`);

    step(2,'loading');
    const pitcherStats = await getPitcherStats(pitcherId);
    step(2, pitcherStats._ok ? 'done' : 'fail',
      pitcherStats._ok ? `✓ ERA ${pitcherStats.era} · ${pitcherStats.ip} IP · ${pitcherStats.gs||0} GS` : `⚠ No stats`);

    step(3,'loading');
    const pitcherX = await getPitcherXStats(pitcherId);
    step(3, pitcherX._ok ? 'done' : 'warn',
      pitcherX._ok ? `✓ xERA ${pitcherX.xera} · xwOBA ${pitcherX.xwoba}` : `⚠ Unavailable`);

    step(4,'loading');
    const pitcherMix = await getPitcherMix(pitcherId);
    step(4, pitcherMix._ok ? 'done' : 'warn',
      pitcherMix._ok ? `✓ K% ${pitcherMix.kPct}% · Whiff% ${pitcherMix.whiff}%` : `⚠ Unavailable`);

    step(5,'loading');
    const schedule = await getSchedule(pitcherBio.currentTeam?.id);
    step(5,'done', schedule.game
      ? `✓ ${schedule.game.away} @ ${schedule.game.home} · ${schedule.gameTime}`
      : `✓ No game today`);

    step(6,'done','—'); step(7,'done','—'); step(8,'done','—');

    step(9,'loading');
    const pitcherAnalysis = buildPitcherAnalysis(pitcherStats, pitcherX, pitcherMix);
    const pitcherHtml = renderPitcherCard(pitcherBio, pitcherStats, pitcherX, pitcherMix, schedule, pitcherAnalysis);

    // Pitcher-only: empty batter card, no clash bar
    document.getElementById('theCard').innerHTML = '';
    document.getElementById('pitcherCard').innerHTML = pitcherHtml;
    document.getElementById('matchupDivider').style.display = 'none';

    step(9,'done','✓ Pitcher card ready');
    await sleep(300);
    show('cardScreen');

  } catch(err) {
    step(getCurrentStep(),'fail',`✗ ${err.message}`);
    console.error(err);
  } finally {
    // Reset step labels back to defaults for next batter search
    document.getElementById('s1t').textContent = 'Player bio · MLB Stats API...';
    document.getElementById('s2t').textContent = 'Hitting stats · MLB Stats API...';
    document.getElementById('s3t').textContent = 'xBA / xSLG / xwOBA · Baseball Savant...';
    document.getElementById('s4t').textContent = 'Barrel% / Hard Hit% / EV · Baseball Savant...';
    document.getElementById('s5t').textContent = 'Schedule + weather · MLB Stats API...';
    document.getElementById('s6t').textContent = 'Pitcher stats · MLB Stats API...';
    document.getElementById('s7t').textContent = 'Pitcher xStats · Baseball Savant...';
    document.getElementById('s8t').textContent = 'Pitcher pitch mix · Baseball Savant...';
    document.getElementById('s9t').textContent = 'Building matchup cards...';
  }
}

async function go(playerId, playerName) {
  drop.classList.remove('open');
  inp.value = '';
  document.getElementById('loadingName').textContent = playerName;
  show('loadingScreen');
  resetSteps();

  try {
    step(1,'loading');
    const bio = await getBio(playerId);
    step(1,'done',`✓ ${bio.fullName} · ${bio.primaryPosition?.abbreviation} · ${bio.currentTeam?.name}`);

    step(2,'loading');
    const hitting = await getHittingStats(playerId);
    step(2, hitting._ok ? 'done' : 'fail',
      hitting._ok ? `✓ ${hitting._label} · ${hitting.pa} PA · AVG ${hitting.avg}` : `⚠ No stats found`);

    step(3,'loading');
    const xstats = await getSavantXStats(playerId);
    step(3, xstats._ok ? 'done' : 'warn',
      xstats._ok ? `✓ xBA ${xstats.xba} · xSLG ${xstats.xslg} · xwOBA ${xstats.xwoba}` : `⚠ ${xstats._error}`);

    step(4,'loading');
    const batted = await getSavantBattedBall(playerId);
    step(4, batted._ok ? 'done' : 'warn',
      batted._ok ? `✓ Barrel% ${batted.brlPct}% · EV95% ${batted.ev95Pct}% · AvgEV ${batted.avgEV}` : `⚠ ${batted._error}`);

    step(5,'loading');
    const schedule = await getSchedule(bio.currentTeam?.id);
    step(5,'done', schedule.game
      ? `✓ ${schedule.game.away} @ ${schedule.game.home} · ${schedule.gameTime}`
      : `✓ No game today`);

    // ── Pitcher card (auto-load from schedule probable pitcher) ──
    const pitcherId = schedule.oppPitcher?.id;
    let pitcherBio=null, pitcherStats=null, pitcherX=null, pitcherMix=null;

    if (pitcherId) {
      step(6,'loading');
      pitcherBio   = await getPitcherBio(pitcherId);
      pitcherStats = await getPitcherStats(pitcherId);
      step(6, pitcherStats._ok ? 'done' : 'fail',
        pitcherStats._ok ? `✓ ${pitcherBio.fullName} · ERA ${pitcherStats.era} · ${pitcherStats.ip} IP` : `⚠ No pitcher stats`);

      step(7,'loading');
      pitcherX = await getPitcherXStats(pitcherId);
      step(7, pitcherX._ok ? 'done' : 'warn',
        pitcherX._ok ? `✓ xERA ${pitcherX.xera} · xBA ${pitcherX.xba}` : `⚠ Pitcher xStats unavailable`);

      step(8,'loading');
      pitcherMix = await getPitcherMix(pitcherId);
      step(8, pitcherMix._ok ? 'done' : 'warn',
        pitcherMix._ok ? `✓ K% ${pitcherMix.kPct}% · Whiff% ${pitcherMix.whiff}%` : `⚠ Pitch mix unavailable`);
    } else {
      step(6,'done','✓ No probable pitcher today');
      step(7,'done','—');
      step(8,'done','—');
    }

    step(9,'loading');
    const analysis = buildAnalysis(hitting, xstats, batted);
    renderCard(bio, hitting, xstats, batted, schedule, analysis);

    // Render pitcher card + clash bar if we have a pitcher
    if (pitcherId) {
      const pitcherAnalysis = buildPitcherAnalysis(pitcherStats, pitcherX, pitcherMix);
      const pitcherHtml = renderPitcherCard(pitcherBio, pitcherStats, pitcherX, pitcherMix, schedule, pitcherAnalysis);
      document.getElementById('pitcherCard').innerHTML = pitcherHtml;
      // Build clash bar
      const clashHtml = buildClashBar(bio, hitting, xstats, batted, pitcherBio, pitcherStats, pitcherX, pitcherMix, schedule);
      document.getElementById('matchupDivider').innerHTML = clashHtml;
      document.getElementById('matchupDivider').style.display = 'block';
    } else {
      document.getElementById('pitcherCard').innerHTML = '';
      document.getElementById('matchupDivider').style.display = 'none';
    }

    step(9,'done','✓ Matchup ready');
    await sleep(300);
    show('cardScreen');

    // Disambiguation: fire if no hitting stats OR if player is TWP
    const isTWP = (bio.primaryPosition?.abbreviation === 'TWP');
    if (!hitting._ok || isTWP) {
      checkPitcherDisambiguation(playerName, isTWP);
    }

  } catch(err) {
    step(getCurrentStep(),'fail',`✗ ${err.message}`);
    console.error(err);
  }
}

