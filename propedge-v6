font-family: ‘Outfit’, sans-serif;
font-size: 22px;
font-weight: 900;
}
.clash-sub {
font-family: ‘Space Grotesk’, sans-serif;
font-size: 10px;
color: var(–muted);
margin-top: 3px;
font-weight: 500;
}
.clash-edge {
padding: 14px 22px;
font-family: ‘Space Grotesk’, sans-serif;
font-size: 13px;
color: var(–muted);
