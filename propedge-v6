/* ─── CLASH BAR ─── */
.matchup-clash {
width: 100%;
max-width: 700px;
background: var(–s1);
border: 1px solid var(–b1);
border-radius: 14px;
overflow: hidden;
}
.clash-header {
background: var(–s2);
border-bottom: 1px solid var(–b1);
padding: 12px 22px;
display: flex;
align-items: center;
