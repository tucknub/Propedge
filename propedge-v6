font-family: ‘Space Mono’, monospace;
transition: all 0.15s;
}
.modal-close:hover { border-color: var(–accent); color: var(–accent); }
.modal-body { padding: 24px 28px 32px; display: flex; flex-direction: column; gap: 22px; }
.modal-section { display: flex; flex-direction: column; gap: 10px; }
.modal-section-title {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
font-weight: 700;
letter-spacing: 3px;
color: var(–accent);
text-transform: uppercase;
padding-bottom: 8px;
border-bottom: 1px solid var(–b1);
}
.modal-p {
font-family: ‘Space Grotesk’, sans-serif;
font-size: 13px;
color: var(–muted);
line-height: 1.7;
}
.modal-p b  { color: var(–text); font-weight: 600; }
.modal-p .g { color: var(–green); }
.modal-p .r { color: var(–red); }
.modal-p .y { color: var(–yellow); }
