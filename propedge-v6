// ── BIO ──
async function getBio(id) {
  // Hydrate currentTeam with sport to enable minor league detection via sport.id
  const res = await fetch(`${MLB}/people/${id}?hydrate=currentTeam`);
  const d   = await res.json();
  if (!d.people?.length) throw new Error('Player not found');
  const person = d.people[0];
  // Fetch team sport data separately for reliable sport.id
  if (person.currentTeam?.id) {
    try {
      const tr = await fetch(`${MLB}/teams/${person.currentTeam.id}`);
      const td = await tr.json();
      const teamData = td.teams?.[0];
      if (teamData?.sport) person.currentTeam.sport = teamData.sport;
      if (teamData?.league) person.currentTeam.league = teamData.league;
    } catch(e) { /* non-fatal, isMinorLeaguer will fall back */ }
  }
  return person;
}

// ── MINOR LEAGUE DETECTION ──
// MLB sport.id = 1. Any other sport.id = affiliated minor league.
// Fallback: MLB league IDs are 103 (AL) and 104 (NL).
function isMinorLeaguer(bio) {
  const sportId = bio?.currentTeam?.sport?.id;
  if (sportId !== undefined && sportId !== null) return sportId !== 1;
  const leagueId = bio?.currentTeam?.league?.id;
  if (leagueId !== undefined && leagueId !== null) return leagueId !== 103 && leagueId !== 104;
  return false;
}

