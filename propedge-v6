<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PropEdge AI · MLB Matchup Engine</title>

<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=Outfit:wght@800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:      #080b10;
    --s1:      #0c1118;
    --s2:      #101620;
    --s3:      #141d28;
    --b1:      #1e2d3d;
    --b2:      #27394f;
    --accent:  #00c8ff;
    --green:   #00e587;
    --red:     #ff4d6a;
    --yellow:  #ffc850;
    --purple:  #9d8cff;
    --orange:  #ff7a35;
    --text:    #e4eeff;
    --muted:   #5a7a96;
    --faint:   #1a2b3c;
    --vfaint:  #0f1a26;
  }

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
background: var(–bg);
font-family: ‘Space Grotesk’, sans-serif;
color: var(–text);
min-height: 100vh;
-webkit-font-smoothing: antialiased;
}

/* ─── SCREENS ─── */
#searchScreen, #loadingScreen, #cardScreen {
display: none;
width: 100%;
}
#searchScreen {
flex-direction: column;
align-items: center;
justify-content: center;
min-height: 100vh;
padding: 48px 24px;
}
#loadingScreen {
flex-direction: column;
align-items: center;
justify-content: center;
min-height: 100vh;
gap: 28px;
padding: 40px 24px;
}
#cardScreen {
flex-direction: column;
align-items: center;
padding: 28px 20px 80px;
min-height: 100vh;
gap: 10px;
}

/* ─── LOGO ─── */
.logo-wrap { text-align: center; margin-bottom: 44px; }
.logo-main {
font-family: ‘Outfit’, sans-serif;
font-size: 56px;
font-weight: 900;
letter-spacing: -2px;
text-transform: uppercase;
line-height: 1;
color: var(–text);
}
.logo-main span { color: var(–accent); }
.logo-sub {
font-family: ‘Space Mono’, monospace;
font-size: 10px;
color: var(–muted);
letter-spacing: 4px;
margin-top: 12px;
text-align: center;
}
.logo-line {
width: 40px;
height: 1px;
background: linear-gradient(90deg, transparent, var(–accent), transparent);
margin: 16px auto 0;
}

/* ─── SEARCH ─── */
.search-wrap { position: relative; width: 100%; max-width: 500px; }
#searchInput {
width: 100%;
background: var(–s2);
border: 1px solid var(–b2);
border-radius: 10px;
padding: 16px 20px;
font-family: ‘Space Grotesk’, sans-serif;
font-size: 16px;
font-weight: 500;
color: var(–text);
outline: none;
transition: border-color 0.2s, box-shadow 0.2s;
caret-color: var(–accent);
}
#searchInput::placeholder { color: var(–muted); font-weight: 400; }
#searchInput:focus {
border-color: var(–accent);
box-shadow: 0 0 0 3px rgba(0,200,255,0.09);
}
#searchDrop {
position: absolute;
top: calc(100% + 6px);
left: 0; right: 0;
background: var(–s2);
border: 1px solid var(–b2);
border-radius: 10px;
overflow: hidden;
z-index: 999;
box-shadow: 0 20px 60px rgba(0,0,0,0.7);
display: none;
}
#searchDrop.open { display: block; }
.sr-item {
padding: 13px 20px;
cursor: pointer;
border-bottom: 1px solid var(–b1);
display: flex;
align-items: center;
justify-content: space-between;
transition: background 0.1s;
}
.sr-item:last-child { border-bottom: none; }
.sr-item:hover { background: var(–s3); }
.sr-name {
font-family: ‘Space Grotesk’, sans-serif;
font-size: 15px;
font-weight: 600;
color: var(–text);
}
.sr-meta {
font-family: ‘Space Mono’, monospace;
font-size: 10px;
color: var(–muted);
}
.search-hint {
font-family: ‘Space Mono’, monospace;
font-size: 10px;
color: var(–muted);
text-align: center;
margin-top: 16px;
letter-spacing: 1px;
}
#searchSubtitle {
font-family: ‘Space Mono’, monospace;
font-size: 10px;
letter-spacing: 3px;
color: var(–muted);
text-align: center;
margin-bottom: 22px;
}

/* ─── MODE TOGGLE ─── */
.mode-toggle {
display: flex;
border: 1px solid var(–b2);
border-radius: 10px;
overflow: hidden;
margin-bottom: 18px;
width: fit-content;
align-self: center;
}
.mode-btn {
padding: 10px 26px;
font-family: ‘Space Grotesk’, sans-serif;
font-size: 13px;
font-weight: 600;
text-transform: uppercase;
letter-spacing: 0.5px;
cursor: pointer;
border: none;
background: transparent;
color: var(–muted);
transition: all 0.15s;
}
.mode-btn.active { background: var(–accent); color: #000; font-weight: 700; }
.mode-btn:hover:not(.active) { color: var(–text); background: var(–s3); }

/* ─── LOADING ─── */
.loading-name {
font-family: ‘Outfit’, sans-serif;
font-size: 38px;
font-weight: 900;
text-transform: uppercase;
letter-spacing: -1px;
color: var(–text);
}
.steps { display: flex; flex-direction: column; gap: 8px; width: 100%; max-width: 380px; }
.step { display: flex; align-items: center; gap: 12px; }
.si {
width: 20px; height: 20px;
border-radius: 50%;
border: 1px solid var(–b2);
display: flex; align-items: center; justify-content: center;
font-size: 9px; flex-shrink: 0;
transition: all 0.3s;
color: var(–muted);
}
.si.loading { border-color: var(–accent); color: var(–accent); animation: pulse 1s infinite; }
.si.done    { border-color: var(–green);  background: rgba(0,229,135,0.1);  color: var(–green); }
.si.fail    { border-color: var(–red);    background: rgba(255,77,106,0.1); color: var(–red); }
.si.warn    { border-color: var(–yellow); background: rgba(255,200,80,0.1); color: var(–yellow); }
.step-txt {
font-family: ‘Space Mono’, monospace;
font-size: 11px;
color: var(–muted);
flex: 1;
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
}

/* ─── NAV BAR ─── */
.nav-bar {
display: flex;
align-items: center;
justify-content: space-between;
width: 100%;
max-width: 700px;
margin-bottom: 6px;
}
.back-btn {
font-family: ‘Space Mono’, monospace;
font-size: 11px;
color: var(–muted);
cursor: pointer;
letter-spacing: 1px;
text-transform: uppercase;
transition: color 0.2s;
}
.back-btn:hover { color: var(–accent); }
.help-btn {
width: 30px; height: 30px;
border-radius: 50%;
background: var(–s2);
border: 1px solid var(–b2);
color: var(–muted);
font-family: ‘Space Grotesk’, sans-serif;
font-size: 14px;
font-weight: 600;
cursor: pointer;
display: flex; align-items: center; justify-content: center;
transition: all 0.15s;
flex-shrink: 0;
}
.help-btn:hover { border-color: var(–accent); color: var(–accent); }

/* ─── CARDS ─── */
.card {
width: 100%;
max-width: 700px;
background: var(–s1);
border: 1px solid var(–b1);
border-radius: 14px;
overflow: hidden;
animation: cardIn 0.35s ease;
}
.pitcher-card {
width: 100%;
max-width: 700px;
background: var(–s1);
border: 1px solid rgba(255,122,53,0.25);
border-radius: 14px;
overflow: hidden;
animation: cardIn 0.35s ease 0.12s both;
}

/* ─── CARD HEADER ─── */
.card-header {
background: var(–s2);
border-bottom: 1px solid var(–b1);
padding: 24px 28px 20px;
display: flex;
justify-content: space-between;
align-items: flex-start;
position: relative;
overflow: hidden;
}
.card-header::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 2px;
background: linear-gradient(90deg, var(–accent) 0%, rgba(0,200,255,0.15) 60%, transparent 100%);
}
.pitcher-card .card-header::before {
background: linear-gradient(90deg, var(–orange) 0%, rgba(255,122,53,0.15) 60%, transparent 100%);
}
.player-name {
font-family: ‘Outfit’, sans-serif;
font-size: 42px;
font-weight: 900;
text-transform: uppercase;
line-height: 1;
letter-spacing: -1px;
color: var(–text);
}
.player-meta {
display: flex;
gap: 0;
align-items: center;
flex-wrap: wrap;
margin-top: 8px;
}
.player-meta b {
font-family: ‘Space Mono’, monospace;
font-size: 10px;
font-weight: 700;
color: var(–accent);
background: rgba(0,200,255,0.08);
border: 1px solid rgba(0,200,255,0.2);
border-radius: 4px;
padding: 2px 7px;
margin-right: 6px;
margin-bottom: 4px;
}
.brand-name {
font-family: ‘Outfit’, sans-serif;
font-size: 12px;
font-weight: 900;
letter-spacing: 1px;
color: var(–accent);
text-align: right;
text-transform: uppercase;
}
.brand-sub {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
color: var(–muted);
margin-top: 4px;
text-align: right;
letter-spacing: 0.5px;
}

/* ─── GAME STRIP ─── */
.game-strip {
background: var(–vfaint);
border-bottom: 1px solid var(–b1);
padding: 10px 28px;
display: flex;
align-items: center;
gap: 10px;
flex-wrap: wrap;
}
.gs-lbl {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
color: var(–muted);
letter-spacing: 2px;
}
.gs-val {
font-family: ‘Space Grotesk’, sans-serif;
font-size: 12px;
color: var(–text);
font-weight: 500;
}
.gs-dot { color: var(–b2); }

/* ─── DATA BANNER ─── */
.data-banner {
margin: 16px 28px 0;
background: var(–vfaint);
border: 1px solid var(–b1);
border-radius: 8px;
padding: 10px 16px;
display: flex;
align-items: center;
gap: 10px;
}
.db-text {
font-family: ‘Space Mono’, monospace;
font-size: 10px;
color: var(–muted);
line-height: 1.6;
flex: 1;
}

/* ─── EDGE BOX ─── */
.edge-box {
margin: 14px 28px 0;
border: 1px solid rgba(0,200,255,0.18);
border-left: 3px solid var(–accent);
border-radius: 8px;
background: rgba(0,200,255,0.03);
padding: 14px 18px;
display: flex;
gap: 14px;
align-items: flex-start;
}
.edge-tag {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
font-weight: 700;
letter-spacing: 2px;
color: var(–accent);
white-space: nowrap;
padding-top: 2px;
text-transform: uppercase;
}
.edge-text {
font-family: ‘Space Grotesk’, sans-serif;
font-size: 13px;
color: var(–muted);
line-height: 1.6;
font-weight: 400;
}
.edge-text b { color: var(–text); font-weight: 600; }

/* ─── SECTION HEADERS ─── */
.sec {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
color: var(–muted);
letter-spacing: 3px;
text-transform: uppercase;
padding: 20px 28px 10px;
display: flex;
align-items: center;
gap: 12px;
}
.sec::after { content: ‘’; flex: 1; height: 1px; background: var(–b1); }
.sec-src {
font-family: ‘Space Mono’, monospace;
font-size: 8px;
color: var(–muted);
font-weight: 400;
text-transform: none;
letter-spacing: 0;
white-space: nowrap;
}

/* ─── SEASON STATS ─── */
.season-row {
display: grid;
grid-template-columns: repeat(6, 1fr);
gap: 6px;
padding: 0 28px;
}
.s-cell {
background: var(–s2);
border: 1px solid var(–b1);
border-radius: 10px;
padding: 14px 8px;
text-align: center;
}
.s-lbl {
font-family: ‘Space Mono’, monospace;
font-size: 8px;
color: var(–muted);
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 6px;
}
.s-val {
font-family: ‘Outfit’, sans-serif;
font-size: 22px;
font-weight: 900;
color: var(–text);
line-height: 1;
}
.s-val.g { color: var(–green); }
.s-val.r { color: var(–red); }
.s-val.b { color: var(–accent); }

/* ─── STAT GRIDS ─── */
.stat-grid   { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; padding: 0 28px; }
.stat-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; padding: 0 28px; }
.stat-grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 6px; padding: 0 28px; }

.stat-cell {
background: var(–s2);
border: 1px solid var(–b1);
border-radius: 10px;
padding: 16px 18px;
}
.stat-cell.hot  { border-color: rgba(0,229,135,0.35); background: rgba(0,229,135,0.04); }
.stat-cell.cold { border-color: rgba(255,77,106,0.35); background: rgba(255,77,106,0.04); }
.stat-cell.lit  { border-color: rgba(0,200,255,0.3);  background: rgba(0,200,255,0.04); }
.stat-cell.warn { border-color: rgba(255,122,53,0.3);  background: rgba(255,122,53,0.03); }

.stat-lbl {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
color: var(–muted);
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 8px;
}
.stat-num {
font-family: ‘Outfit’, sans-serif;
font-size: 32px;
font-weight: 900;
line-height: 1;
}
.stat-num.g { color: var(–green); }
.stat-num.r { color: var(–red); }
.stat-num.b { color: var(–accent); }
.stat-num.w { color: var(–text); }
.stat-num.o { color: var(–orange); }
.stat-sub {
font-family: ‘Space Grotesk’, sans-serif;
font-size: 11px;
margin-top: 4px;
font-weight: 500;
color: var(–muted);
line-height: 1.4;
}
.up { color: var(–green); }
.dn { color: var(–red); }
.nt { color: var(–muted); }

/* ─── REGRESSION BARS ─── */
.reg-section { padding: 0 28px; display: flex; flex-direction: column; gap: 8px; }
.reg-row { display: flex; align-items: center; gap: 10px; }
.reg-lbl {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
color: var(–muted);
width: 44px;
flex-shrink: 0;
letter-spacing: 1px;
text-transform: uppercase;
}
.reg-track {
flex: 1;
height: 24px;
background: var(–vfaint);
border: 1px solid var(–b1);
border-radius: 5px;
overflow: hidden;
}
.reg-fill {
height: 100%;
display: flex;
align-items: center;
padding-left: 10px;
border-radius: 4px;
}
.reg-fill-lbl {
font-family: ‘Space Mono’, monospace;
font-size: 8px;
font-weight: 700;
color: rgba(255,255,255,0.85);
white-space: nowrap;
}
.reg-actual {
font-family: ‘Space Mono’, monospace;
font-size: 11px;
width: 40px;
text-align: right;
flex-shrink: 0;
color: var(–text);
}
.reg-gap {
font-family: ‘Outfit’, sans-serif;
font-size: 13px;
font-weight: 800;
padding: 3px 8px;
border-radius: 5px;
width: 60px;
text-align: center;
flex-shrink: 0;
}
.reg-gap.pos { background: rgba(0,229,135,0.1); color: var(–green); border: 1px solid rgba(0,229,135,0.25); }
.reg-gap.neg { background: rgba(255,77,106,0.1); color: var(–red);   border: 1px solid rgba(255,77,106,0.25); }
.reg-gap.neu { background: var(–vfaint);          color: var(–muted); border: 1px solid var(–b1); }

/* ─── MATCHUP ROW ─── */
.matchup-row {
margin: 0 28px;
background: var(–s2);
border: 1px solid var(–b1);
border-radius: 10px;
display: grid;
grid-template-columns: repeat(4, 1fr);
overflow: hidden;
}
.mq-cell {
padding: 14px 12px;
text-align: center;
border-right: 1px solid var(–b1);
}
.mq-cell:last-child { border-right: none; }
.mq-lbl {
font-family: ‘Space Mono’, monospace;
font-size: 8px;
color: var(–muted);
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 6px;
}
.mq-val {
font-family: ‘Outfit’, sans-serif;
font-size: 16px;
font-weight: 800;
color: var(–text);
}

/* ─── PROP ROWS ─── */
.prop-section { padding: 0 28px; display: flex; flex-direction: column; gap: 6px; }
.prop-row {
display: flex;
align-items: stretch;
background: var(–s2);
border: 1px solid var(–b1);
border-radius: 10px;
overflow: hidden;
}
.prop-market {
font-family: ‘Outfit’, sans-serif;
font-size: 14px;
font-weight: 800;
text-transform: uppercase;
padding: 13px 18px;
width: 152px;
flex-shrink: 0;
border-right: 1px solid var(–b1);
display: flex;
align-items: center;
color: var(–text);
}
.prop-detail {
font-family: ‘Space Grotesk’, sans-serif;
font-size: 12px;
color: var(–muted);
padding: 13px 16px;
flex: 1;
line-height: 1.6;
display: flex;
align-items: center;
}
.prop-detail b { color: var(–text); font-weight: 600; font-size: 13px; }
.prop-ev {
font-family: ‘Outfit’, sans-serif;
font-size: 17px;
font-weight: 900;
padding: 13px 10px;
border-left: 1px solid var(–b1);
width: 86px;
text-align: center;
flex-shrink: 0;
display: flex;
align-items: center;
justify-content: center;
}
.prop-rec {
font-family: ‘Outfit’, sans-serif;
font-size: 12px;
font-weight: 800;
letter-spacing: 0.5px;
padding: 13px 10px;
border-left: 1px solid var(–b1);
width: 76px;
text-align: center;
flex-shrink: 0;
display: flex;
align-items: center;
justify-content: center;
}
.rec-over  { background: rgba(0,229,135,0.07); color: var(–green); }
.rec-under { background: rgba(255,77,106,0.07); color: var(–red); }
.rec-watch { background: var(–vfaint); color: var(–muted); }

.prop-disclaimer {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
color: var(–muted);
padding: 6px 28px;
line-height: 1.7;
opacity: 0.6;
}

/* ─── EDITABLE LINE INPUT ─── */
.prop-line-wrap {
display: flex;
align-items: center;
gap: 6px;
border-left: 1px solid var(–b1);
padding: 8px 12px;
flex-shrink: 0;
background: var(–vfaint);
min-width: 94px;
}
.prop-line-lbl {
font-family: ‘Space Mono’, monospace;
font-size: 8px;
color: var(–muted);
letter-spacing: 1px;
white-space: nowrap;
}
.prop-line-input {
width: 58px;
background: var(–s3);
border: 1px solid var(–b2);
border-radius: 6px;
padding: 5px 4px;
font-family: ‘Outfit’, sans-serif;
font-size: 17px;
font-weight: 900;
color: var(–accent);
text-align: center;
outline: none;
transition: border-color 0.15s, box-shadow 0.15s;
-moz-appearance: textfield;
}
.prop-line-input::-webkit-outer-spin-button,
.prop-line-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.prop-line-input:focus {
border-color: var(–accent);
box-shadow: 0 0 0 2px rgba(0,200,255,0.12);
}
.prop-line-input:hover { border-color: var(–muted); }

/* ─── CARD FOOTER ─── */
.card-footer {
border-top: 1px solid var(–b1);
margin-top: 20px;
padding: 14px 28px;
background: var(–s2);
display: flex;
justify-content: space-between;
align-items: flex-start;
gap: 16px;
}
.footer-src {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
color: var(–muted);
line-height: 1.8;
max-width: 60%;
}
.footer-ts {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
color: var(–muted);
text-align: right;
line-height: 2;
}
.footer-ts span { color: var(–accent); }

/* ─── BADGES ─── */
.badge {
display: inline-block;
border-radius: 5px;
padding: 2px 8px;
font-family: ‘Space Mono’, monospace;
font-size: 9px;
letter-spacing: 0.5px;
font-weight: 700;
}
.badge-live    { background: rgba(0,229,135,0.1);  border: 1px solid rgba(0,229,135,0.3);  color: var(–green); }
.badge-partial { background: rgba(255,200,80,0.08); border: 1px solid rgba(255,200,80,0.25); color: var(–yellow); }
.badge-spring  { background: rgba(157,140,255,0.1); border: 1px solid rgba(157,140,255,0.3); color: var(–purple); }
.badge-prior   { background: rgba(255,122,53,0.08); border: 1px solid rgba(255,122,53,0.25); color: var(–orange); }
.badge-minor   { background: rgba(255,200,80,0.1);  border: 1px solid rgba(255,200,80,0.4);  color: var(–yellow); }

/* ─── PITCH MIX ─── */
.pitch-mix-row {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 6px;
padding: 0 28px;
}
.pitch-cell {
background: var(–s2);
border: 1px solid var(–b1);
border-radius: 10px;
padding: 12px 14px;
}
.pitch-name {
font-family: ‘Space Mono’, monospace;
font-size: 8px;
color: var(–muted);
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 4px;
}
.pitch-pct {
font-family: ‘Outfit’, sans-serif;
font-size: 24px;
font-weight: 900;
color: var(–text);
line-height: 1;
}
.pitch-velo {
font-family: ‘Space Mono’, monospace;
font-size: 9px;
color: var(–muted);
